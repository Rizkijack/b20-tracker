# B20 Scanner Environment Variables

# ─── Blockchain RPC ───────────────────────────────────────────────────────────
# Base Mainnet RPC endpoint. Defaults to https://mainnet.base.org if unset.
# Use Alchemy, Infura, or QuickNode for production for better rate limits.
#
# SERVER-ONLY RPC (preferred, never sent to the browser):
#   BASE_RPC_URL supports a comma-separated list for automatic rotation
#   on rate limits, e.g.
#   BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/KEY,https://mainnet.base.org
# If BASE_RPC_URL is unset, the server falls back to NEXT_PUBLIC_BASE_RPC_URL,
# then the public endpoint.
BASE_RPC_URL=
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Optional cross-instance cache (Redis / Upstash).
# When set, discovered tokens & market data survive serverless cold-starts
# instead of resetting on every deploy / warm instance.
# Upstash is preferred for Vercel; requires both URL and token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy fallback URL (used if UPSTASH_REDIS_REST_URL is unset)
REDIS_URL=

# ─── Market Data APIs (server-side only) ──────────────────────────────────────
# All keys below are kept server-side and used by Next.js API routes.
# They are NEVER exposed to the browser.
#
# ⚠️ DO NOT paste real keys here if you plan to commit this file.
# For Vercel: add these in Dashboard → Settings → Environment Variables.
# For local dev: put keys in .env.local (already gitignored).

# Birdeye.so — free tier API key (optional)
# Get yours at: https://birdeye.so/user/profile
BIRDEYE_API_KEY=

# CoinGecko — free or pro API key (optional; free tier works without key)
# Pro key removes rate limits: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# CoinMarketCap — free tier API key (optional)
# Get yours at: https://pro.coinmarketcap.com/signup
COINMARKETCAP_API_KEY=

# ─── Data Source Priority ─────────────────────────────────────────────────────
# You can force-disable sources by changing the priority list in the UI hook.
# By default all sources are queried:
#   dexscreener (free, no key)
#   geckoterminal (free, no key)
#   birdeye (requires BIRDEYE_API_KEY)
#   coingecko (free tier available)
#   coinmarketcap (requires COINMARKETCAP_API_KEY)
