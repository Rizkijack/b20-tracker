# B20 Tracker Environment Variables
# Copy this file to .env.local for local development

# Base Mainnet RPC URL (defaults to public endpoint if not set)
# For production, use a dedicated RPC provider for better rate limits:
#   - Alchemy:      https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#   - Infura:       https://base-mainnet.infura.io/v3/YOUR_API_KEY
#   - QuickNode:    https://YOUR_ENDPOINT.base-mainnet.quiknode.pro/YOUR_KEY/
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
