# B20 Tracker Environment Variables
# Copy this file to .env.local for local development

# ─── Base Mainnet RPC ──────────────────────────────────────────────────────
# Defaults to public endpoint. For production, use a dedicated RPC provider:
#   Alchemy:   https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#   Infura:    https://base-mainnet.infura.io/v3/YOUR_API_KEY
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# ─── Vercel KV / Upstash Redis (Shared Cache) ─────────────────────────────
# Used by serverless API routes to share cache across all function instances.
# Falls back to in-memory cache if not configured (fine for local dev).
# Get these from Vercel Dashboard → Storage → KV / Upstash Redis.
# KV_REST_API_URL=https://your-region.upstash.io
# KV_REST_API_TOKEN=your-token
#
# Or using Upstash directly:
# UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
#
# Without these, cache is local to each serverless function instance.

# ─── ISR Config ───────────────────────────────────────────────────────────
# Token detail pages use ISR with revalidate=60 seconds.
# No additional env vars needed.
